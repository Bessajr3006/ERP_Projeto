# Exemplo de configuração (desenvolvimento)

NODE_ENV=development
PORT=3030

# Banco (MariaDB/MySQL)
DB_HOST=127.0.0.1
DB_PORT=3308
DB_NAME=bessa_erp
DB_USER=root
DB_PASSWORD=troque_esta_senha

# Auth
JWT_SECRET=troque_por_um_segredo_longo
JWT_EXPIRES_IN=90d
SALT_ROUNDS=10

# Criptografia (64 chars hex)
ENCRYPTION_KEY=gere_uma_chave_hexadecimal_com_64_caracteres

# Opcional: usado apenas para gerar tipos via kysely-codegen
# DATABASE_URL=mysql://root:troque_esta_senha@127.0.0.1:3308/bessa_erp
