# Exemplo de configuração (produção / docker compose)

NODE_ENV=production
PORT=3000
TZ=America/Sao_Paulo

# Conexão do backend com o banco
DB_HOST=db
DB_PORT=3306
DB_NAME=bessa_erp
DB_USER=root
DB_PASSWORD=30mariafn@

# Bootstrap do container MariaDB
MARIADB_DATABASE=bessa_erp
MARIADB_USER=erp_user
MARIADB_PASSWORD=30mariafn@
MARIADB_ROOT_PASSWORD=30mariafn@

# Login preferencial no phpMyAdmin
PMA_USER=root
PMA_PASSWORD=30mariafn@

# Auth
JWT_SECRET=troque_por_um_segredo_longo
JWT_EXPIRES_IN=24h
SALT_ROUNDS=10

# Criptografia (64 chars hex)
ENCRYPTION_KEY=chave_hexadecimal_64_chars

# Traefik / Portainer
TRAEFIK_CERTRESOLVER=myresolver
TRAEFIK_PUBLIC_NETWORK_NAME=traefik

# Volumes / rede
MARIADB_VOLUME_NAME=mariadb
APP_DATA_VOLUME_NAME=projeto_erp_bessa_app_data
ERP_INTERNAL_NETWORK_NAME=projeto_erp_bessa_internal

# phpMyAdmin
PHPMYADMIN_UPLOAD_LIMIT=256M
